# Optional dev: serve clips from public/videos/ instead of Vercel Blob (see quiz.json URLs).
# VITE_USE_LOCAL_VIDEOS=true

# Or override a single clip:
# VITE_VIDEO_KLIPP1=/videos/klipp1.mp4
# VITE_VIDEO_KLIPP2=/videos/klipp2.mp4

# Upload / CLI (not used by the Vite app): BLOB_READ_WRITE_TOKEN from Vercel → Storage → naturfag-videos
